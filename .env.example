# Database (existing)
DATABASE_USERNAME=
DATABASE_PASSWORD=

# AI Analyst — Azure OpenAI. Set these on Render (dashboard → Environment).
# The key is a secret; never commit the real value.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://ed-gpt.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Embeddings deployment used for AI-Analyst intent routing (same key/endpoint as above).
# Optional — defaults to "text-embedding-3-large". If this deployment is missing or
# unreachable, routing degrades gracefully (fail-open) and the chatbot still works.
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large
